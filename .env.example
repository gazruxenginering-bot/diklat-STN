# Environment Configuration for STN Diklat Panel

# ===========================================
# SECURITY SETTINGS
# ===========================================

# SECRET_KEY - REQUIRED for production
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Flask Environment
FLASK_ENV=production  # development, production

# CSRF Protection - set to False to disable temporarily (development/testing only)
WTF_CSRF_ENABLED=True

# API Keys for offline/API access (comma-separated)
API_KEYS=offline-dev-key-123,your-api-key-here

# IP Whitelist for CSRF exemption (comma-separated)
IP_WHITELIST=127.0.0.1,localhost

# ===========================================
# DATABASE SETTINGS
# ===========================================

# For production, consider using PostgreSQL or MySQL
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost/dbname
# Or keep SQLite for simple deployments
# SQLALCHEMY_DATABASE_URI=sqlite:///database/users.db

# ===========================================
# CSP SETTINGS
# ===========================================

# CSP_LEVEL=strict      # Maximum security (default)
# CSP_LEVEL=permissive  # Allow unsafe-eval for compatibility
# CSP_LEVEL=disabled    # No CSP (not recommended)

# ===========================================
# SERVER SETTINGS
# ===========================================

# For production deployment
# HOST=0.0.0.0
# PORT=8000
# DEBUG=False

# ===========================================
# EMAIL SETTINGS (Optional)
# ===========================================

# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ===========================================
# GOOGLE DRIVE API (Optional)
# ===========================================

# GOOGLE_DRIVE_CREDENTIALS_PATH=credentials.json
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# ===========================================
# GEMINI API FOR RAG CHAT FEATURE (REQUIRED for Chat)
# ===========================================

# Get your API key from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=AIzaSyBnOam5Cak2qYnV3tZ5b67q_yIJdQUcxeY

# Chat configuration (optional)
# CHAT_MODEL=gemini-1.5-flash
# CHAT_TEMPERATURE=0.7
# CHAT_MAX_HISTORY=20
# CHAT_CHUNK_SIZE=1000
# CHAT_SEARCH_LIMIT=5
# CHAT_TOP_CHUNKS=3

# ===========================================
# CHROMA VECTOR DATABASE SETTINGS
# ===========================================

# Use Chroma Cloud (true) or Local Chroma (false)
CHROMA_CLOUD=true

# CHROMA CLOUD SETTINGS (if CHROMA_CLOUD=true)
# Get credentials from: https://www.trychroma.com/gazruxenginering/aws-us-east-1/DIKLAT-STN/source
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=ck-4XMkqE5Wi5DfzQEkcso6N8RSf1PtewXD5wU4UBXTn81n
CHROMA_TENANT=5926624f-3d5b-4c04-875f-66d530572b0a
CHROMA_DATABASE=DIKLAT-STN

# LOCAL CHROMA SETTINGS (if CHROMA_CLOUD=false)
# CHROMA_PERSIST_DIR=./chroma_data

# ===========================================
# ADMIN SETTINGS
# ===========================================

# Admin API key untuk akses admin endpoints
ADMIN_API_KEY=your-secret-admin-key-change-this